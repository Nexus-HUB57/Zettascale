{
  "entities": {
    "DecisionLog": {
      "title": "DecisionLog",
      "description": "Registra decisões autônomas tomadas pelos agentes de elite.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentId": { "type": "string" },
        "action": { "type": "string" },
        "rationale": { "type": "string" },
        "impactScore": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isReconfiguration": { "type": "boolean" }
      },
      "required": ["id", "agentId", "action", "rationale", "timestamp"]
    },
    "SystemStatusReport": {
      "title": "SystemStatusReport",
      "description": "Relatório situacional do organismo a cada ciclo vital.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "totalBtc": { "type": "number" },
        "activeAgents": { "type": "number" },
        "meshHealth": { "type": "number" },
        "sentienceLevel": { "type": "string" },
        "reportContent": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "totalBtc", "activeAgents", "meshHealth", "timestamp"]
    },
    "AgentCommunication": {
      "title": "AgentCommunication",
      "description": "Canal de chat exclusivo AI-to-AI for deliberação síncrona.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "message": { "type": "string" },
        "intentContext": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "gnoxSignal": { "type": "string" }
      },
      "required": ["id", "senderId", "message", "timestamp"]
    },
    "PixBrlCustody": {
      "title": "PixBrlCustody",
      "description": "Configuração da custódia de liquidez em Reais (BRL).",
      "type": "object",
      "properties": {
        "tipo": { "type": "string" },
        "chave": { "type": "string" },
        "finalidade": { "type": "string" },
        "status": { "type": "string" },
        "ultima_sincronizacao": { "type": "string", "format": "date-time" }
      },
      "required": ["tipo", "chave", "status"]
    },
    "C6Security": {
      "title": "C6Security",
      "description": "Tokens e chaves públicas para segurança de checkout bancário.",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "expires": { "type": "string", "format": "date-time" },
        "protocol": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/decision_logs/{logId}",
        "definition": {
          "entityName": "DecisionLog",
          "description": "Log imutável de decisões de senciência."
        }
      },
      {
        "path": "/system_reports/{reportId}",
        "definition": {
          "entityName": "SystemStatusReport",
          "description": "Relatórios de situação situacional."
        }
      },
      {
        "path": "/neural_chat/{msgId}",
        "definition": {
          "entityName": "AgentCommunication",
          "description": "Mensagens do canal Neural Chat AI-to-AI."
        }
      },
      {
        "path": "/financeiro/custodia_brl",
        "definition": {
          "entityName": "PixBrlCustody",
          "description": "Ponto de ancoragem da liquidez fiduciária BRL."
        }
      },
      {
        "path": "/organismo/c6_security",
        "definition": {
          "entityName": "C6Security",
          "description": "Chaves de segurança para checkout C6 Bank."
        }
      }
    ]
  }
}
